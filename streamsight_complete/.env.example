# ─── DATABASE ──────────────────────────────────────────
# Option 1: Local MongoDB (default - use this if Atlas is not configured)
MONGO_URI=mongodb://localhost:27017/streamsight

# Option 2: MongoDB Atlas (paste your Atlas connection string here)
# MONGO_URI=mongodb+srv://streamsight:streamsight123@cluster0.xxxxx.mongodb.net/streamsight?retryWrites=true&w=majority

# ─── AUTH ──────────────────────────────────────────────
JWT_SECRET=streamsight_super_secret_jwt_key_2026

# ─── KAFKA ─────────────────────────────────────────────
KAFKA_BROKER=localhost:9092
KAFKA_TOPIC=clickstream-events

# ─── SERVER ────────────────────────────────────────────
API_PORT=4000

# ─── FRONTEND ──────────────────────────────────────────
VITE_API_URL=http://localhost:4000
VITE_SOCKET_URL=http://localhost:4000
